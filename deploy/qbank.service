# systemd unit for the Sci-Oly question-bank app (bare metal, no Docker).
#
# Install:
#   sudo cp deploy/qbank.service /etc/systemd/system/qbank.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now qbank
#
# Assumes:
#   - A dedicated, non-root `qbank` system user already exists
#     (sudo useradd -r -m -d /opt/qbank -s /sbin/nologin qbank)
#   - The repo is cloned to /opt/qbank/app, with a venv at /opt/qbank/venv
#     (python3 -m venv /opt/qbank/venv && /opt/qbank/venv/bin/pip install
#      -r /opt/qbank/app/requirements.txt)
#   - /opt/qbank/.env holds ANTHROPIC_API_KEY, FLASK_SECRET_KEY,
#     SESSION_COOKIE_SECURE=true (once served over HTTPS), and
#     APPLICATION_ROOT (set to the reverse proxy's mount path, e.g.
#     /testbank/ncms, if the app isn't served from the domain root) —
#     see .env.example
#
# --workers 1 is load-bearing: build_question_bank.py's per-event state lock
# is an in-process threading.RLock, which only serialises writes correctly
# within a single worker process. --threads gives real concurrency for the
# I/O-bound LLM calls without that risk. Don't raise --workers above 1
# without first replacing that lock with a file-based one.

[Unit]
Description=Sci-Oly question-bank Flask app (gunicorn)
After=network.target

[Service]
Type=simple
User=qbank
Group=qbank
WorkingDirectory=/opt/qbank/app
EnvironmentFile=/opt/qbank/.env
ExecStart=/opt/qbank/venv/bin/gunicorn --workers 1 --threads 8 --bind 127.0.0.1:5000 --timeout 120 review_app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
