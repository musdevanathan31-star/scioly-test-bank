# Copy this file to .env and fill in your Anthropic API key.
# The key is used only for vision-based image assignment and OCR
# of image-based PDFs (Claude Haiku, cheapest model).
#
# Without the key the script still works in text-only mode.

ANTHROPIC_API_KEY=sk-ant-...

# Production-only settings — leave unset for local dev (python review_app.py).

# Signs session cookies. Set this for any shared/production deployment so
# logins survive a process restart; without it the app falls back to a
# throwaway per-process key and everyone gets logged out on restart.
# Generate with: openssl rand -hex 32
FLASK_SECRET_KEY=

# Only mark the session cookie Secure once actually served over HTTPS (e.g.
# behind Caddy) — over plain HTTP the browser would refuse to send it at all.
SESSION_COOKIE_SECURE=true

# Set this if the reverse proxy mounts the app under a path prefix instead of
# the domain root (e.g. https://scioly-02864.com/testbank/ncms/). Leave unset
# to serve from the domain root. See review_app.py's _PrefixMiddleware.
APPLICATION_ROOT=/testbank/ncms

# Where per-event DATA (PDFs, images, generated markdown, state/job files),
# auth_users.json, events_custom.json, and the shared textbooks/ directory
# live — separate from the app's code directory, e.g. a bigger/dedicated
# disk mount. Optional: defaults to the app directory itself if unset, so
# existing deployments need no changes. Only set this on a box that already
# has data under the app directory after following the migration runbook in
# README.md's "Maintaining the server" section — setting it on a running
# instance without first moving the data makes the app start writing/reading
# a second, empty copy at the new location instead of finding what's already there.
DATA_ROOT=/mnt/qbank-data
